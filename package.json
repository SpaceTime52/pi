{
  "name": "@jeonghyeon-net/pi",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run test:all && npm run test:structure",
    "test:structure": "go test ./...",
    "test:subagent": "c8 --all --100 --include='extensions/subagent/**/*.ts' --exclude='extensions/subagent/__tests__/**' --exclude='extensions/subagent/index.ts' --exclude='extensions/subagent/core/deps.ts' --exclude='extensions/subagent/execution/runner.ts' --exclude='extensions/subagent/ui/history-overlay.ts' --exclude='extensions/subagent/ui/replay.ts' --exclude='extensions/subagent/tool/types.ts' --exclude='extensions/subagent/tool/render.ts' --exclude='extensions/subagent/register/commands.ts' --exclude='extensions/subagent/register/tools.ts' --exclude='extensions/subagent/register/events.ts' --exclude='extensions/subagent/register/input.ts' --exclude='extensions/subagent/register/commands/sub-run.ts' --exclude='extensions/subagent/register/commands/sub-manage.ts' tsx --test --test-force-exit extensions/subagent/__tests__/*.test.ts",
    "test:claude-mcp-bridge": "c8 --all --100 --include='extensions/claude-mcp-bridge/core/**' --exclude='extensions/claude-mcp-bridge/core/bridge.ts' --exclude='extensions/claude-mcp-bridge/core/connection.ts' --exclude='extensions/claude-mcp-bridge/core/manager.ts' --exclude='extensions/claude-mcp-bridge/core/overlay-action.ts' --exclude='extensions/claude-mcp-bridge/core/overlay-status.ts' --exclude='extensions/claude-mcp-bridge/core/overlay-tools.ts' --exclude='extensions/claude-mcp-bridge/core/types.ts' tsx --test extensions/claude-mcp-bridge/__tests__/*.test.ts",
    "test:claude-hooks-bridge": "c8 --all --100 --include='extensions/claude-hooks-bridge/core/**' --exclude='extensions/claude-hooks-bridge/__tests__/**' tsx --test extensions/claude-hooks-bridge/__tests__/*.test.ts",
    "test:cross-agent": "c8 --all --100 --include='extensions/cross-agent/core/**' --exclude='extensions/cross-agent/__tests__/**' --exclude='extensions/cross-agent/core/types.ts' tsx --test extensions/cross-agent/__tests__/*.test.ts",
    "test:all": "npm run test:subagent && npm run test:claude-mcp-bridge && npm run test:claude-hooks-bridge && npm run test:cross-agent",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-tui": "^0.64.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@sinclair/typebox": "^0.34.49",
    "c8": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "yaml": "^2.8.0"
  }
}
