{
  "name": "@jeonghyeon-net/pi",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "go test ./...",
    "test:subagent": "c8 --100 --include='extensions/subagent/**/*.ts' --exclude='extensions/subagent/__tests__/**' tsx --test extensions/subagent/__tests__/*.test.ts",
    "test:all": "npm run test:subagent",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-tui": "^0.64.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@sinclair/typebox": "^0.34.49",
    "c8": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "yaml": "^2.8.0"
  }
}
