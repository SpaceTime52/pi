# MCP secrets — iCloud Drive 밖에 보관할 것 권장.
# 사용법:
#   1) 이 파일을 ~/.config/pi/mcp.env 같은 곳으로 복사
#   2) 실제 값을 채운 뒤 ~/.zshrc 에:
#        set -a; source ~/.config/pi/mcp.env; set +a
#      를 추가하면 모든 셸에서 export 됨.
#
# (source 시 변수명이 그대로 노출되므로 'set -a' 로 export 자동화)

# ─── Atlassian (mcp-atlassian: Jira + Confluence) ───────────────────────────
export ATLASSIAN_API_TOKEN=""

# ─── GitHub ──────────────────────────────────────────────────────────────────
export GITHUB_PERSONAL_ACCESS_TOKEN=""

# ─── Figma ───────────────────────────────────────────────────────────────────
export FIGMA_API_KEY=""

# ─── Notion (공식 notion-mcp-server) ─────────────────────────────────────────
export NOTION_TOKEN=""

# ─── Creatrip Internal MCP (creatrip-internal) ───────────────────────────────
# ※ 위의 ATLASSIAN_API_TOKEN / NOTION_TOKEN 과 다른 키를 사용 중이라 분리.
export CREATRIP_JIRA_TOKEN=""
export CREATRIP_NOTION_TOKEN=""
export CREATRIP_SLACK_BOT_TOKEN=""
export CREATRIP_API_AUTH_TOKEN=""

# ─── Creatrip DBA MCP (HTTP, Bearer JWT) ─────────────────────────────────────
export CREATRIP_DBA_MCP_TOKEN=""

# ─── AWS Athena (@lishenxydlgzs/aws-athena-mcp) ──────────────────────────────
export ATHENA_OUTPUT_S3_PATH="s3://your-bucket/athena-results/"
export AWS_REGION="ap-northeast-2"
# AWS_PROFILE 또는 AWS_ACCESS_KEY_ID/SECRET 중 하나만 채우면 됨
export AWS_PROFILE="default"
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_SESSION_TOKEN=""
export ATHENA_WORKGROUP="primary"

# ─── Apollo MCP Server ───────────────────────────────────────────────────────
# 별도로 apollo-mcp-server 를 띄운 뒤 그 endpoint URL 을 넣어야 함.
# 예: rover dev / docker run ghcr.io/apollographql/apollo-mcp-server:latest
# 또는 GraphOS Studio 그래프 사용 시 APOLLO_KEY/APOLLO_GRAPH_REF 와 함께 별도 실행.
export APOLLO_MCP_URL="http://127.0.0.1:8000/mcp"
